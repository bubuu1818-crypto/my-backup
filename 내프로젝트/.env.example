# Instagram Graph API
IG_ACCESS_TOKEN=your_long_lived_access_token_here
IG_USER_ID=your_instagram_business_account_id

# 인스타그램 이미지 호스팅용 공개 URL (ngrok 또는 실서버)
# 예: https://abc123.ngrok.io  또는  https://yourdomain.com
BASE_URL=http://localhost:5000

# Node.js 경로 (Windows 기본값)
NODE_BIN=C:\Program Files\nodejs
